{
  "title": "Emotion Inference",
  "uid": "emotion-inference",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Predictions per minute",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(emotion_predictions_total[1m])) * 60",
          "legendFormat": "predictions/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "ms" }, "overrides": [] },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "(rate(emotion_prediction_latency_seconds_sum[1m]) / rate(emotion_prediction_latency_seconds_count[1m])) * 1000",
          "legendFormat": "avg latency",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Predictions by label",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (label) (rate(emotion_predictions_total[1m]) * 60)",
          "legendFormat": "{{label}}",
          "refId": "A"
        }
      ]
    }
  ]
}
